<main class="relative z-10 overflow-hidden px-6 pt-36 md:px-10">
  <section class="relative mx-auto grid min-h-[92vh] max-w-[1600px] items-center gap-16 lg:grid-cols-[.46fr_.54fr]">
    <div class="relative z-20 max-w-2xl">
      <div class="bloom active inline-flex items-center gap-3 rounded-full border border-white/10 bg-white/[0.03] px-5 py-3 font-sans text-[11px] uppercase tracking-[0.3em] text-white/55">
        <div class="h-2 w-2 rounded-full bg-reactor shadow-[0_0_15px_rgba(97,218,251,.9)] pulse-react"></div>
        Biophilic Data Binding Active
      </div>

      <h1 class="mt-8 font-serif text-[4.8rem] leading-[.9] tracking-[-0.08em] text-white md:text-[7rem] xl:text-[8.5rem]">
        <span class="wind-sway">Reactive</span><br>
        Forest Logic
      </h1>

      <p class="mt-8 max-w-xl font-body text-lg leading-9 text-white/50 md:text-xl">
        A React-native operating system for regenerative estates. State-driven architecture powering geothermal villas, photovoltaic envelopes, and intelligent forest equilibrium.
      </p>

      <div class="mt-12 flex flex-wrap items-center gap-5">
        <button class="dew rounded-[2rem] px-8 py-5 font-sans text-[12px] uppercase tracking-[0.24em] text-white">
          Launch Ecosystem
        </button>

        <button class="rounded-[2rem] border border-white/10 bg-white/[0.03] px-8 py-5 font-sans text-[12px] uppercase tracking-[0.24em] text-white/65 backdrop-blur-xl transition hover:bg-white/[0.05] hover:text-white">
          Explore Runtime
        </button>
      </div>

      <div class="mt-16 flex flex-wrap gap-5">
        <div class="liquid-panel rounded-[2rem] px-6 py-5">
          <div class="font-sans text-[10px] uppercase tracking-[0.28em] text-white/40">Energy State</div>
          <div class="mt-3 text-3xl font-semibold">98%</div>
        </div>

        <div class="liquid-panel rounded-[2rem] px-6 py-5">
          <div class="font-sans text-[10px] uppercase tracking-[0.28em] text-white/40">Reactive Nodes</div>
          <div class="mt-3 text-3xl font-semibold">240</div>
        </div>
      </div>
    </div>

    <div class="relative flex items-center justify-center lg:justify-end">
      <div class="organic-shell scroll-grow relative aspect-[.95] w-full max-w-[880px] float-core hero-video">
        <video autoplay muted loop playsinline class="h-full w-full object-cover saturate-[1.2] contrast-[1.08] brightness-[.9] mix-blend-screen">
          <source src="<%= asset_path('video.mp4') %>" type="video/mp4">
        </video>

        <div class="absolute inset-0 bg-[radial-gradient(circle_at_center,transparent_20%,rgba(5,7,11,.65)_100%)]"></div>
      </div>
    </div>

    <div class="light-river bottom-0"></div>
  </section>

  <section class="relative mx-auto mt-32 max-w-[1600px]">
    <div class="absolute left-[20%] top-0 h-72 w-72 rounded-full bg-[radial-gradient(circle,rgba(97,218,251,.12),transparent_70%)] blur-3xl"></div>

    <div class="flex flex-col gap-16">
      <div class="max-w-4xl bloom">
        <div class="font-sans text-[11px] uppercase tracking-[0.32em] text-white/35">Virtual Ecosystem</div>
        <h2 class="mt-6 font-serif text-5xl leading-[1] tracking-[-0.07em] text-white md:text-7xl">
          Reactivity designed like a living biome.
        </h2>
      </div>

      <div class="flex flex-col gap-8 lg:flex-row lg:items-stretch">
        <article class="liquid-panel bloom flex-1 rounded-[3rem] p-8 md:p-10">
          <div class="flex items-center justify-between">
            <div class="font-sans text-[10px] uppercase tracking-[0.28em] text-white/35">Component Modularity</div>
            <div class="h-3 w-3 rounded-full bg-reactor pulse-react"></div>
          </div>

          <h3 class="mt-8 max-w-sm font-serif text-4xl leading-tight tracking-[-0.06em]">
            Dynamic villa systems powered by reactive state.
          </h3>

          <p class="mt-6 max-w-xl text-lg leading-8 text-white/50">
            Every villa node synchronizes lighting, geothermal balance, and photovoltaic consumption through a unified component architecture.
          </p>
        </article>

        <article class="liquid-panel bloom rounded-[3rem] p-8 md:w-[32rem]">
          <div class="font-sans text-[10px] uppercase tracking-[0.28em] text-white/35">Hydration Metrics</div>

          <div class="mt-8 space-y-6">
            <div>
              <div class="mb-2 flex items-center justify-between text-sm text-white/50">
                <span>Forest Sync</span>
                <span>96%</span>
              </div>
              <div class="h-2 overflow-hidden rounded-full bg-white/10">
                <div class="h-full w-[96%] rounded-full bg-reactor"></div>
              </div>
            </div>

            <div>
              <div class="mb-2 flex items-center justify-between text-sm text-white/50">
                <span>Energy Flow</span>
                <span>82%</span>
              </div>
              <div class="h-2 overflow-hidden rounded-full bg-white/10">
                <div class="h-full w-[82%] rounded-full bg-chlorophyll"></div>
              </div>
            </div>

            <div>
              <div class="mb-2 flex items-center justify-between text-sm text-white/50">
                <span>Virtual Ecology</span>
                <span>91%</span>
              </div>
              <div class="h-2 overflow-hidden rounded-full bg-white/10">
                <div class="h-full w-[91%] rounded-full bg-white"></div>
              </div>
            </div>
          </div>
        </article>
      </div>
    </div>
  </section>
</main>
